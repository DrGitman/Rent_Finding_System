FROM node:20-alpine

WORKDIR /app

# Install deps separately for better layer caching
COPY package.json package-lock.json* ./
RUN npm install

# App code is mounted as a volume in dev mode
# (node_modules stays in the container layer — not overwritten by the volume)

EXPOSE 3000

ENV NEXT_TELEMETRY_DISABLED=1
ENV WATCHPACK_POLLING=true

CMD ["npm", "run", "dev"]
